# API base URL for the Scholarship Finder frontend (baked in at build time).
# Option A – Proxy via Node server (recommended when using npm start): set VITE_API_URL=/api and API_BACKEND_URL to your Lambda URL.
# Option B – Direct to Lambda: set VITE_API_URL to your API Gateway URL (no trailing slash).
# Get ApiUrl: aws cloudformation describe-stacks --stack-name scholarship-finder --query "Stacks[0].Outputs[?OutputKey=='ApiUrl'].OutputValue" --output text
#
# VITE_API_URL=/api
# API_BACKEND_URL=https://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com/prod

# Contact us link on home page (mailto:)
# VITE_CONTACT_EMAIL=your@email.com

# Cognito (from same stack Outputs: UserPoolId, UserPoolClientId)
# VITE_COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
# VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
# For "Sign in with Cognito" (Hosted UI) on CloudFront or static build. Stack output: CognitoOAuthDomain
# VITE_COGNITO_OAUTH_DOMAIN=scholarship-finder-ui.auth.us-east-1.amazoncognito.com

# Cognito OIDC server (app.js hosted UI flow). Configure your user pool app client with:
# - Allowed callback URLs: same as COGNITO_CALLBACK_URL below
# - Allowed sign-out URLs: same as COGNITO_LOGOUT_URI (e.g. http://localhost:3000/)
# - Allowed OAuth flows: Authorization code grant
# - OpenID Connect scopes: openid, email, profile
#
# Required for /api/profile when using Cognito sign-in: use same pool as frontend. COGNITO_CLIENT_ID must equal VITE_COGNITO_CLIENT_ID.
# COGNITO_ISSUER_URL=https://cognito-idp.us-east-1.amazonaws.com/us-east-1_xxxxxxxxx
# COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
# Required if your app client has a secret (Hosted UI token exchange). Get it from Cognito → App client → Show client secret
# COGNITO_CLIENT_SECRET=your-client-secret-from-cognito
# COGNITO_CALLBACK_URL=http://localhost:3000/callback
# COGNITO_LOGOUT_DOMAIN=https://your-domain.auth.us-east-1.amazonaws.com
# COGNITO_LOGOUT_URI=http://localhost:3000/
# SESSION_SECRET=use-a-long-random-string-in-production

# Profile (About You) storage – DynamoDB table name. Create via SAM (backend/template.yaml outputs ProfilesTableName).
# AWS credentials: use default chain (e.g. AWS_PROFILE, env vars, or IAM role when on EC2).
# PROFILES_TABLE=Profiles
# AWS_REGION=us-east-1
