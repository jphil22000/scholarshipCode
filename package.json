{
  "name": "scholarship-finder",
  "version": "1.0.0",
  "description": "A web application to search for college scholarships and help students apply",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "node server.js",
    "dev:all": "concurrently \"npm run dev:server\" \"npm run dev\"",
    "dev:full": "concurrently \"npm start\" \"npm run dev\"",
    "build": "vite build",
    "preview": "vite preview",
    "lambda:deploy": "cd backend && npm run deploy",
    "lambda:deploy:personal": "cd backend && AWS_PROFILE=personal npm run deploy",
    "deploy:website": "./scripts/deploy-website.sh",
    "deploy:website:personal": "AWS_PROFILE=personal ./scripts/deploy-website.sh",
    "lambda:test": "cd backend && npm test",
    "aws:test": "aws sts get-caller-identity --profile personal",
    "start": "node app.js"
  },
  "keywords": [
    "scholarships",
    "education",
    "vue",
    "aws"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.997.0",
    "@aws-sdk/lib-dynamodb": "^3.997.0",
    "aws-amplify": "^6.16.2",
    "axios": "^1.6.7",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.21.1",
    "express-session": "^1.18.1",
    "jose": "^6.1.3",
    "openid-client": "^5.7.0",
    "pinia": "^2.1.7",
    "vue": "^3.4.21",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.0",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "vite": "^7.3.1"
  }
}
